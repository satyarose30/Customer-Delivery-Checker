<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="Domus_CustomerDeliveryChecker::css/checkout-pincode.css"/>
    </head>
    <body>
        <referenceBlock name="checkout.root">
            <arguments>
                <argument name="jsLayout" xsi:type="array">
                    <item name="components" xsi:type="array">
                        <item name="checkout" xsi:type="array">
                            <item name="children" xsi:type="array">
                                <item name="steps" xsi:type="array">
                                    <item name="children" xsi:type="array">
                                        <item name="shipping-step" xsi:type="array">
                                            <item name="children" xsi:type="array">
                                                <item name="shippingAddress" xsi:type="array">
                                                    <item name="children" xsi:type="array">
                                                        <item name="shipping-address-fieldset" xsi:type="array">
                                                            <item name="children" xsi:type="array">
                                                                <item name="domus-pincode-checker" xsi:type="array">
                                                                    <item name="component" xsi:type="string">
                                                                        Domus_CustomerDeliveryChecker/js/view/checkout/pincode-checker
                                                                    </item>
                                                                    <item name="displayArea" xsi:type="string">
                                                                        shipping-address-fieldset
                                                                    </item>
                                                                    <item name="dataScope" xsi:type="string">
                                                                        domus-pincode-checker
                                                                    </item>
                                                                    <item name="provider" xsi:type="string">
                                                                        checkoutProvider
                                                                    </item>
                                                                    <item name="config" xsi:type="array">
                                                                        <item name="template" xsi:type="string">
                                                                            Domus_CustomerDeliveryChecker/checkout/pincode-checker
                                                                        </item>
                                                                        <item name="checkUrl" xsi:type="url" path="domus/rest/check"/>
                                                                        <item name="defaultCountry" xsi:type="string">IN</item>
                                                                    </item>
                                                                </item>
                                                            </item>
                                                        </item>
                                                    </item>
                                                </item>
                                            </item>
                                        </item>
                                    </item>
                                </item>
                            </item>
                        </item>
                    </item>
                </argument>
            </arguments>
        </referenceBlock>
    </body>
</page>
