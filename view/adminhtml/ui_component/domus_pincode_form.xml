<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">domus_pincode_form.domus_pincode_form_data_source</item>
            <item name="deps" xsi:type="string">domus_pincode_form.domus_pincode_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Pincode Information</item>
        <item name="config" xsi:type="array">
            <item name="dataScope" xsi:type="string">data</item>
            <item name="namespace" xsi:type="string">domus_pincode_form</item>
        </item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
        <item name="buttons" xsi:type="array">
            <item name="back" xsi:type="string">Domus\CustomerDeliveryChecker\Block\Adminhtml\Pincode\Edit\BackButton</item>
            <item name="save" xsi:type="string">Domus\CustomerDeliveryChecker\Block\Adminhtml\Pincode\Edit\SaveButton</item>
            <item name="reset" xsi:type="string">Domus\CustomerDeliveryChecker\Block\Adminhtml\Pincode\Edit\ResetButton</item>
        </item>
    </argument>
    <dataSource name="domus_pincode_form_data_source">
        <argument name="dataProvider" xsi:type="configurableObject">
            <argument name="class" xsi:type="string">Domus\CustomerDeliveryChecker\Model\Pincode\DataProvider</argument>
            <argument name="name" xsi:type="string">domus_pincode_form_data_source</argument>
            <argument name="primaryFieldName" xsi:type="string">entity_id</argument>
            <argument name="requestFieldName" xsi:type="string">id</argument>
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="submit_url" xsi:type="url" path="customerdeliverychecker/pincode/save"/>
                </item>
            </argument>
        </argument>
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
    </dataSource>

    <fieldset name="general">
        <argument name="data" xsi:type="array">
            <item name="config" xsi:type="array">
                <item name="label" xsi:type="string" translate="true">General Information</item>
                <item name="collapsible" xsi:type="boolean">true</item>
                <item name="opened" xsi:type="boolean">true</item>
            </item>
        </argument>

        <field name="entity_id">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="visible" xsi:type="boolean">false</item>
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">pincode</item>
                </item>
            </argument>
        </field>

        <field name="pincode">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Pincode/Zip Code</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">pincode</item>
                    <item name="validation" xsi:type="array">
                        <item name="required-entry" xsi:type="boolean">true</item>
                    </item>
                </item>
            </argument>
        </field>

        <field name="country_id" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">pincode</item>
                </item>
            </argument>
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Country</label>
            </settings>
            <formElements>select</formElements>
            <settings>
                <options class="Magento\Directory\Model\Config\Source\Country"/>
            </settings>
        </field>

        <field name="city">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">City</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">pincode</item>
                </item>
            </argument>
        </field>

        <field name="state">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">State</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">pincode</item>
                </item>
            </argument>
        </field>

        <field name="area_name">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Area/Locality</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">pincode</item>
                </item>
            </argument>
        </field>

        <field name="latitude">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Latitude</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">pincode</item>
                    <item name="notice" xsi:type="string" translate="true">For Google Maps integration</item>
                </item>
            </argument>
        </field>

        <field name="longitude">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Longitude</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">pincode</item>
                    <item name="notice" xsi:type="string" translate="true">For Google Maps integration</item>
                </item>
            </argument>
        </field>
    </fieldset>

    <fieldset name="delivery_settings">
        <argument name="data" xsi:type="array">
            <item name="config" xsi:type="array">
                <item name="label" xsi:type="string" translate="true">Delivery Settings</item>
                <item name="collapsible" xsi:type="boolean">true</item>
                <item name="opened" xsi:type="boolean">true</item>
            </item>
        </argument>

        <field name="is_deliverable" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">pincode</item>
                    <item name="default" xsi:type="number">1</item>
                </item>
            </argument>
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Is Deliverable</label>
            </settings>
            <formElements>checkbox</formElements>
        </field>

        <field name="is_cod_available" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">pincode</item>
                </item>
            </argument>
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">COD Available</label>
            </settings>
        </field>

        <field name="estimated_delivery_days">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">number</item>
                    <item name="label" xsi:type="string" translate="true">Estimated Delivery Days</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">pincode</item>
                    <item name="notice" xsi:type="string" translate="true">Number of days for delivery</item>
                </item>
            </argument>
        </field>

        <field name="shipping_charge">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Shipping Charge</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">pincode</item>
                </item>
            </argument>
        </field>

        <field name="cod_charge">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">COD Additional Charge</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">pincode</item>
                </item>
            </argument>
        </field>

        <field name="is_active" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">pincode</item>
                    <item name="default" xsi:type="number">1</item>
                </item>
            </argument>
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Active</label>
            </settings>
        </field>

        <field name="priority">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">number</item>
                    <item name="label" xsi:type="string" translate="true">Priority</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">pincode</item>
                    <item name="notice" xsi:type="string" translate="true">Higher priority rules are checked first</item>
                </item>
            </argument>
        </field>
    </fieldset>

    <fieldset name="restrictions">
        <argument name="data" xsi:type="array">
            <item name="config" xsi:type="array">
                <item name="label" xsi:type="string" translate="true">Restrictions (Optional)</item>
                <item name="collapsible" xsi:type="boolean">true</item>
                <item name="opened" xsi:type="boolean">false</item>
            </item>
        </argument>

        <field name="weight_from">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Weight From (kg)</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">pincode</item>
                </item>
            </argument>
        </field>

        <field name="weight_to">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Weight To (kg)</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">pincode</item>
                </item>
            </argument>
        </field>

        <field name="price_from">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Price From</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">pincode</item>
                </item>
            </argument>
        </field>

        <field name="price_to">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Price To</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">pincode</item>
                </item>
            </argument>
        </field>

        <field name="store_id" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">pincode</item>
                    <item name="notice" xsi:type="string" translate="true">Leave empty for all stores</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Store View</label>
            </settings>
            <formElements>select</formElements>
            <settings>
                <options class="Magento\Store\Ui\Component\Listing\Column\Store\Options"/>
            </settings>
        </field>

        <field name="customer_group_id" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">pincode</item>
                    <item name="notice" xsi:type="string" translate="true">Leave empty for all customer groups</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Customer Group</label>
            </settings>
            <formElements>select</formElements>
            <settings>
                <options class="Magento\Customer\Ui\Component\Listing\Column\Group\Options"/>
            </settings>
        </field>
    </fieldset>

    <fieldset name="category_product_restriction">
        <argument name="data" xsi:type="array">
            <item name="config" xsi:type="array">
                <item name="label" xsi:type="string" translate="true">Category &amp; Product Restrictions</item>
                <item name="collapsible" xsi:type="boolean">true</item>
                <item name="opened" xsi:type="boolean">false</item>
            </item>
        </argument>

        <field name="categories">
            <argument name="data" xsi:type="array">
                <item name="options" xsi:type="object">Magento\Catalog\Ui\Component\Product\Form\Categories\Options</item>
                <item name="config" xsi:type="array">
                    <item name="label" xsi:type="string" translate="true">Categories</item>
                    <item name="component" xsi:type="string">Magento_Catalog/js/components/new-category-form</item>
                    <item name="formElement" xsi:type="string">select</item>
                    <item name="elementTmpl" xsi:type="string">ui/grid/filters/elements/ui-select</item>
                    <item name="dataScope" xsi:type="string">categories</item>
                    <item name="filterOptions" xsi:type="boolean">true</item>
                    <item name="showCheckbox" xsi:type="boolean">true</item>
                    <item name="disableLabel" xsi:type="boolean">true</item>
                    <item name="multiple" xsi:type="boolean">true</item>
                    <item name="levelsVisibility" xsi:type="string">1</item>
                    <item name="sortOrder" xsi:type="number">20</item>
                    <item name="notice" xsi:type="string" translate="true">Select categories for which this pincode restriction applies. Leave empty for all categories.</item>
                </item>
            </argument>
        </field>

        <field name="products">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="label" xsi:type="string" translate="true">Products</item>
                    <item name="component" xsi:type="string">Magento_Ui/js/form/element/ui-select</item>
                    <item name="formElement" xsi:type="string">select</item>
                    <item name="elementTmpl" xsi:type="string">ui/grid/filters/elements/ui-select</item>
                    <item name="dataScope" xsi:type="string">products</item>
                    <item name="filterOptions" xsi:type="boolean">true</item>
                    <item name="showCheckbox" xsi:type="boolean">true</item>
                    <item name="disableLabel" xsi:type="boolean">true</item>
                    <item name="multiple" xsi:type="boolean">true</item>
                    <item name="listens" xsi:type="array">
                        <item name="isNewCreation" xsi:type="string">toggleOption</item>
                    </item>
                    <item name="sortOrder" xsi:type="number">30</item>
                    <item name="notice" xsi:type="string" translate="true">Select specific products. Leave empty for all products.</item>
                    <item name="options" xsi:type="array"/>
                    <item name="config" xsi:type="array">
                        <item name="searchUrl" xsi:type="url" path="customerdeliverychecker/pincode/productSearch"/>
                    </item>
                </item>
            </argument>
        </field>
    </fieldset>
</form>
